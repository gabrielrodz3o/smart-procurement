# ============================================================
# SMART-PROCUREMENT — Variables de entorno
# En el servidor: cp .env.example .env  y rellena los valores
# ============================================================

# --- Base de datos (en Docker usa el nombre del contenedor/servicio) ---
DB_HOST=pgbouncer
DB_PORT=6432
DB_DATABASE=gcode
DB_USER=dev_gabriel
DB_PASSWORD=TU_PASSWORD_AQUI

# --- OpenAI (requerido para /explain y /generate) ---
OPENAI_API_KEY=sk-...

# --- Redis (el contenedor interno del compose, no cambiar en producción) ---
REDIS_URL=redis://redis:6379/0

# --- Nightly scheduler (APScheduler corre /generate a las 02:00 AM) ---
# Formato: business_unit_id:location_id separados por coma
# Dejar vacío para deshabilitar
NIGHTLY_UNITS=16:12

# --- Entorno ---
ENVIRONMENT=production
