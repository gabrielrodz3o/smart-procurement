# ============================================================
# PURCHASING-AI MICROSERVICE — Environment Variables Example
# Copy to .env and fill in your values
# ============================================================

# --- Database ---
DB_PORT=6432
DB_HOST=localhost          # production: pgbouncer
DB_DATABASE=gcode
DB_USER=dev_gabriel
DB_PASSWORD=your_password_here

# Constructed URL (used by asyncpg / SQLAlchemy)
DATABASE_URL=postgresql://dev_gabriel:your_password_here@localhost:6432/gcode

# --- OpenAI (optional — for LLM explanations) ---
OPENAI_API_KEY=sk-...

# --- Redis (optional — for model cache) ---
REDIS_URL=redis://localhost:6379

# --- Nightly scheduler (APScheduler runs /generate at 02:00 AM) ---
# Format: business_unit_id:location_id comma-separated
# Leave empty to disable
NIGHTLY_UNITS=16:12,17:15

# --- Service ---
PORT=8001
ENVIRONMENT=development    # production
